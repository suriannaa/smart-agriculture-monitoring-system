        <mxCell id="e4" value="triggers alerts" style="endArrow=block;html=1;rounded=0;strokeColor=#38761d;strokeWidth=2;fontSize=12;fontFamily=Times New Roman;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="system" target="m4">
          <mxGeometry relative="1" as="geometry"/>
